<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="OpenCart Test Suite">
    <listeners>
        <listener class-name="listeners.TestListeners"/>
    </listeners>

    <test verbose="2" name="SearchTests">
        <classes>
            <class name="tests.SearchFunctionality.SearchHappyPathTests">
                <methods>
                    <include name="validateSuccessfulSearchWithExistingProduct"/>
                    <include name="validateUnsuccessfulSearchWithNonExistingProduct"/>
                </methods>
            </class>
            <class name="tests.SearchFunctionality.SearchNegativeTests">
                <methods>
                    <include name="validateUnsuccessfulSearchWithEmptyProduct"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
